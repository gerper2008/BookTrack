-- Validar cliente
DECLARE
    vResult NUMBER;
BEGIN
    vResult := pkg_Cliente.VALIDAR_CLIENTE('C000000001');
    DBMS_OUTPUT.PUT_LINE('Cliente válido: ' || vResult);
END;
/

-- Ver historial de préstamos
DECLARE
    vCursor SYS_REFCURSOR;
    vID     VARCHAR2(10);
    vFecha  DATE;
    vDias   NUMBER;
    vTitulo VARCHAR2(60);
BEGIN
    vCursor := pkg_Cliente.VE_HISTORIAL_PRESTAMOS('C000000001');
    LOOP
        FETCH vCursor INTO vID, vFecha, vDias, vTitulo;
        EXIT WHEN vCursor%NOTFOUND;
        DBMS_OUTPUT.PUT_LINE(vTitulo || ' | Retraso: ' || vDias);
    END LOOP;
    CLOSE vCursor;
END;
/

-- Ver multas pendientes del cliente
DECLARE
    vCursor SYS_REFCURSOR;
    vID     VARCHAR2(10);
    vMonto  NUMBER;
    vMotivo VARCHAR2(30);
    vEst    VARCHAR2(20);
BEGIN
    vCursor := pkg_Cliente.VE_MULTAS_PENDIENTES('C000000001');
    LOOP
        FETCH vCursor INTO vID, vMonto, vMotivo, vEst;
        EXIT WHEN vCursor%NOTFOUND;
        DBMS_OUTPUT.PUT_LINE(vID || ' | ' || vMotivo || ' | $' || vMonto);
    END LOOP;
    CLOSE vCursor;
END;
/