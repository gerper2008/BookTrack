-- -------------------------------------------------------
-- Probar pkg_Bibliotecario
-- -------------------------------------------------------

-- A) Registrar préstamo (corregido: incluye xID_BIBLIOTECARIO)
BEGIN
    pkg_Bibliotecario.AD_PRESTAMO(
        xID_BIBLIOTECARIO => 'USR003',        -- Bibliotecario que realiza el prestamo
        xID_CLIENTE      => 'USR005',      -- Cliente que pide el prestamo
        xID_EJEMPLAR    => 'EJM001',      -- Ejemplar a prestar
        xFECHA_PRESTAMO => SYSDATE
    );
END;
/

-- C) Consultar préstamos por fecha
DECLARE
    vCursor SYS_REFCURSOR;
    vID     VARCHAR2(10);
    vFecha  DATE;
    vDias   NUMBER;
    vNombre VARCHAR2(60);
    vApell  VARCHAR2(60);
    vEjem   VARCHAR2(10);
BEGIN
    vCursor := pkg_Bibliotecario.CO_PRESTAMO(SYSDATE);
    LOOP
        FETCH vCursor INTO vID, vFecha, vDias, vNombre, vApell, vEjem;
        EXIT WHEN vCursor%NOTFOUND;
        DBMS_OUTPUT.PUT_LINE(vID || ' | ' || vNombre || ' | Retraso: ' || vDias);
    END LOOP;
    CLOSE vCursor;
END;
/

-- A) Registrar devolución (corregido: incluye xID_BIBLIOTECARIO)
BEGIN
    pkg_Bibliotecario.AD_DEVOLUCION(
        xID_BIBLIOTECARIO => 'USR003',         -- Bibliotecario que recibe
        xID_PRESTAMO      => 'PR000000001',   -- ID del prestamo a devolver
        xESTADO_ENTREGA   => 1,
        xOBSERVACIONES   => 'Libro devuelto en buen estado'
    );
END;
/

