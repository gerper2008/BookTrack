/

-- A) Registrar multa por retraso
BEGIN
    pkg_Bibliotecario.AD_MULTA(
        xID_DEVOLUCION   => 'D000000001',
        xMOTIVO          => 'Retraso',
        xMONTO_ACUMULADO => 15000
