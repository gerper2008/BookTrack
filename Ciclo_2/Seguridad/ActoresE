-- ========================
-- PKG: Bibliotecario
-- ========================
CREATE OR REPLACE PACKAGE pkg_Bibliotecario AS

    -- PRESTAMO (corregido: incluye xID_BIBLIOTECARIO)
    PROCEDURE AD_PRESTAMO(
        xID_BIBLIOTECARIO IN VARCHAR2,
        xID_CLIENTE      IN VARCHAR2,
        xID_EJEMPLAR     IN VARCHAR2,
        xFECHA_PRESTAMO  IN DATE
    );
    PROCEDURE MOD_PRESTAMO(
        xID             IN VARCHAR2,
        xFECHA_PRESTAMO IN DATE
    );
    PROCEDURE ELI_PRESTAMO(
        xID       IN VARCHAR2,
        xID_ADMIN IN VARCHAR2
    );
    FUNCTION CO_PRESTAMO(
        xFECHA_PRESTAMO IN DATE
    ) RETURN SYS_REFCURSOR;

    -- DEVOLUCION (corregido: incluye xID_BIBLIOTECARIO)
    PROCEDURE AD_DEVOLUCION(
        xID_BIBLIOTECARIO IN VARCHAR2,
        xID_PRESTAMO     IN VARCHAR2,
        xESTADO_ENTREGA  IN NUMBER,
        xOBSERVACIONES   IN VARCHAR2
    );
    PROCEDURE MOD_DEVOLUCION(
        xID            IN VARCHAR2,
        xOBSERVACIONES IN VARCHAR2
    );
    PROCEDURE ELI_DEVOLUCION(
        xID IN VARCHAR2
    );
    FUNCTION CO_DEVOLUCION(
        xESTADO_ENTREGA IN NUMBER
    ) RETURN SYS_REFCURSOR;

    -- MULTA
    PROCEDURE AD_MULTA(
        xID_DEVOLUCION  IN VARCHAR2,
        xMOTIVO         IN VARCHAR2,
        xMONTO_ACUMULADO IN NUMBER
    );
    PROCEDURE MOD_MULTA(
        xID              IN VARCHAR2,
        xMONTO_ACUMULADO IN NUMBER,
        xESTADO          IN VARCHAR2
    );
    PROCEDURE ELI_MULTA(
        xID       IN VARCHAR2,
        xID_ADMIN IN VARCHAR2
    );
    FUNCTION CO_MULTA(
        xESTADO IN VARCHAR2
    ) RETURN SYS_REFCURSOR;

    -- PAGO
    PROCEDURE AD_PAGO(
        xID_MULTA      IN VARCHAR2,
        xMONTO_ABONADO IN NUMBER,
        xMETODO_PAGO   IN VARCHAR2
    );
    PROCEDURE MOD_PAGO(
        xID          IN VARCHAR2,
        xMETODO_PAGO IN VARCHAR2
    );
    PROCEDURE ELI_PAGO(
        xID IN VARCHAR2
    );
    FUNCTION CO_PAGO(
        xESTADO IN VARCHAR2
    ) RETURN SYS_REFCURSOR;

    -- VISTAS DE CONSULTA
    FUNCTION VE_EJEMPLARES_DISPONIBLES RETURN SYS_REFCURSOR;
    FUNCTION VE_PRESTAMOS_ACTIVOS RETURN SYS_REFCURSOR;
    FUNCTION VE_ESTADO_FISICO_EJEMPLARES RETURN SYS_REFCURSOR;
    FUNCTION VE_MULTAS_GENERADAS(xESTADO IN VARCHAR2) RETURN SYS_REFCURSOR;
    FUNCTION VE_DEVOLUCIONES_REGISTRADAS(xFECHA IN DATE) RETURN SYS_REFCURSOR;

END pkg_Bibliotecario;
/

-- ========================
-- PKG: Cliente
-- ========================
CREATE OR REPLACE PACKAGE pkg_Cliente AS

    FUNCTION VALIDAR_CLIENTE(xID IN VARCHAR2) RETURN NUMBER;
    FUNCTION VERIFICAR_ESTADO_CLIENTE(xID_CLIENTE IN VARCHAR2) RETURN VARCHAR2;
    FUNCTION VERIFICAR_SALDO_CLIENTE(xID_CLIENTE IN VARCHAR2) RETURN NUMBER;
    FUNCTION VERIFICAR_VENCIMIENTO_CLIENTE(xID_CLIENTE IN VARCHAR2) RETURN DATE;

    FUNCTION VE_DISPONIBILIDAD_LIBRO(xID_LIBRO IN VARCHAR2) RETURN SYS_REFCURSOR;
    FUNCTION VE_HISTORIAL_PRESTAMOS(xID_CLIENTE IN VARCHAR2) RETURN SYS_REFCURSOR;
    FUNCTION VE_PRESTAMOS_ACTIVOS_CLIENTE(xID_CLIENTE IN VARCHAR2) RETURN SYS_REFCURSOR;
    FUNCTION VE_MULTAS_PENDIENTES(xID_CLIENTE IN VARCHAR2) RETURN SYS_REFCURSOR;
    FUNCTION VE_ESTADO_PAGO_MULTA(xID_MULTA IN VARCHAR2) RETURN SYS_REFCURSOR;

END pkg_Cliente;
/